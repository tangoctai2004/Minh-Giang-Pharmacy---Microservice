# ─────────────────────────────────────────────────────────
# Root .env — Được docker-compose.yml đọc tự động
# Copy file này thành .env   rồi điền giá trị thực
# ─────────────────────────────────────────────────────────

# JWT — PHẢI đặt giống nhau cho api-gateway và identity-service
JWT_SECRET=change_me_to_a_random_32_char_string

# CORS — Các domain frontend được phép gọi API
# Dùng dev local: không cần thay
CORS_ORIGIN=http://localhost:5500,http://localhost:3000

# ─── Email (nodemailer / notification-service) ───────────
# Dùng Gmail App Password (bật 2FA → https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
