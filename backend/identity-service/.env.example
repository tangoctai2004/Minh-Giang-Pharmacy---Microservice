# ─────────────────────────────────────────────────────────────
# Identity Service — Environment Variables
# cp .env.example .env   rồi điền giá trị thực
# ─────────────────────────────────────────────────────────────

PORT=8001
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=root
DB_NAME=mg_identity

# JWT — dùng cùng giá trị với api-gateway
JWT_SECRET=change_me_to_a_random_32_char_string
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=30d

# URL của API Gateway (để CORS nội bộ nếu cần)
GATEWAY_URL=http://localhost:8000
