# ─────────────────────────────────────────────────────────────
# API Gateway — Environment Variables
# Sao chép file này thành .env rồi điền giá trị thực
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Cổng Gateway (mặc định 8000)
PORT=8000

# Môi trường chạy: development | production
NODE_ENV=development

# JWT Secret — PHẢI THAY BẰNG CHUỖI NGẪU NHIÊN >= 32 KÝ TỰ
# Có thể tạo bằng: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TUYỆT ĐỐI KHÔNG COMMIT file .env lên git!
JWT_SECRET=change_me_to_a_random_32_char_string

# URLs của các microservice
# Dev local  → giữ nguyên localhost
# Docker     → thay bằng tên service trong docker-compose (vd: http://identity-service:8001)
IDENTITY_SERVICE_URL=http://localhost:8001
CATALOG_SERVICE_URL=http://localhost:8002
ORDER_SERVICE_URL=http://localhost:8003
CMS_SERVICE_URL=http://localhost:8004
NOTIFICATION_SERVICE_URL=http://localhost:8005

# CORS — danh sách domain frontend được phép gọi API (phân cách bằng dấu phẩy)
# CORS_ORIGIN=http://localhost:5500,http://localhost:3000

